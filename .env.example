# Supabase connection for ENLIST (signups) + ECHOMAIL (forum).
# Copy to .env.local for local dev:  cp .env.example .env.local
# Find these in Supabase Dashboard → Project Settings → API.
# The anon key is safe to expose in the client — Row Level Security (see
# supabase/schema.sql) is what protects the data, not secrecy of this key.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
